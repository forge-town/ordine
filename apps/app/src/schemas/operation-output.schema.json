{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationOutput",
  "description": "Structured output from pipeline operations. Discriminated by the \"type\" field.",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "check"
        },
        "summary": {
          "type": "string",
          "description": "Executive summary of the check results"
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this finding, e.g. 'ERR_001'"
              },
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "info"]
              },
              "message": {
                "type": "string",
                "description": "One-line summary of the issue"
              },
              "file": {
                "type": "string",
                "description": "Relative file path from project root"
              },
              "line": {
                "description": "Line number (1-based) if applicable",
                "type": "number"
              },
              "rule": {
                "description": "Rule or standard violated, e.g. 'no-try-catch'",
                "type": "string"
              },
              "snippet": {
                "description": "Short code snippet showing the violation",
                "type": "string"
              },
              "suggestion": {
                "description": "Suggested fix or recommendation",
                "type": "string"
              },
              "skipped": {
                "description": "True if this finding is an allowed exception and should not be fixed",
                "type": "boolean"
              },
              "skipReason": {
                "description": "Why this finding was skipped (e.g. 'framework boundary')",
                "type": "string"
              }
            },
            "required": ["id", "severity", "message", "file"],
            "additionalProperties": false
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalFiles": {
              "type": "number",
              "description": "Number of files scanned"
            },
            "totalFindings": {
              "type": "number",
              "description": "Total findings count"
            },
            "errors": {
              "type": "number"
            },
            "warnings": {
              "type": "number"
            },
            "infos": {
              "type": "number"
            },
            "skipped": {
              "type": "number",
              "description": "Findings marked as allowed exceptions"
            }
          },
          "required": ["totalFiles", "totalFindings", "errors", "warnings", "infos", "skipped"],
          "additionalProperties": false
        }
      },
      "required": ["type", "summary", "findings", "stats"],
      "additionalProperties": false,
      "title": "CheckOutput"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "fix"
        },
        "summary": {
          "type": "string",
          "description": "Summary of all changes made"
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative file path that was modified"
              },
              "action": {
                "type": "string",
                "enum": ["replace", "create", "delete"]
              },
              "description": {
                "type": "string",
                "description": "What was changed"
              },
              "findingId": {
                "description": "The finding ID this change addresses",
                "type": "string"
              }
            },
            "required": ["file", "action", "description"],
            "additionalProperties": false
          }
        },
        "remainingFindings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this finding, e.g. 'ERR_001'"
              },
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "info"]
              },
              "message": {
                "type": "string",
                "description": "One-line summary of the issue"
              },
              "file": {
                "type": "string",
                "description": "Relative file path from project root"
              },
              "line": {
                "description": "Line number (1-based) if applicable",
                "type": "number"
              },
              "rule": {
                "description": "Rule or standard violated, e.g. 'no-try-catch'",
                "type": "string"
              },
              "snippet": {
                "description": "Short code snippet showing the violation",
                "type": "string"
              },
              "suggestion": {
                "description": "Suggested fix or recommendation",
                "type": "string"
              },
              "skipped": {
                "description": "True if this finding is an allowed exception and should not be fixed",
                "type": "boolean"
              },
              "skipReason": {
                "description": "Why this finding was skipped (e.g. 'framework boundary')",
                "type": "string"
              }
            },
            "required": ["id", "severity", "message", "file"],
            "additionalProperties": false
          },
          "description": "Findings that could not be auto-fixed"
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalChanges": {
              "type": "number"
            },
            "filesModified": {
              "type": "number"
            },
            "findingsFixed": {
              "type": "number"
            },
            "findingsSkipped": {
              "type": "number"
            }
          },
          "required": ["totalChanges", "filesModified", "findingsFixed", "findingsSkipped"],
          "additionalProperties": false
        }
      },
      "required": ["type", "summary", "changes", "remainingFindings", "stats"],
      "additionalProperties": false,
      "title": "FixOutput"
    }
  ],
  "discriminator": {
    "propertyName": "type"
  }
}
