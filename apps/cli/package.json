{
  "name": "@ordine/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "ordine": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun src/index.ts",
    "check-types": "tsc --noEmit",
