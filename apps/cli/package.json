    "quality": "bun run check-types && bun run lint && bun run test",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "*",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
